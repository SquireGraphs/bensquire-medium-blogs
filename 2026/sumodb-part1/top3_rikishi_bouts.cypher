  {boutId: '202309-D2-12165-12836', matchupId: '12165-12836', bashoId: '202309', bashoName: '2023.09', dayId: '202309-D2', day: 2, dateLabel: '2023.09-Day2', eastId: '12836', eastName: 'Onosato', eastRank: 'J14e', eastTitle: '大の里, Nishonoseki, Ishikawa, 07.06.2000, 2023.05, , 192 cm 177 kg, J14', eastDisplayText: 'J14e Onosato', westId: '12165', westName: 'Yuma', westRank: 'Ms1w', westTitle: '勇磨, Onomatsu, Osaka, 13.06.1998, 2014.03, , 178 cm 122 kg, J14', westDisplayText: 'Ms1w Yuma', winnerId: '12836', winnerName: 'Onosato', winnerRank: 'J14e', winnerTitle: '大の里, Nishonoseki, Ishikawa, 07.06.2000, 2023.05, , 192 cm 177 kg, J14', loserId: '12165', loserName: 'Yuma', loserRank: 'Ms1w', loserTitle: '勇磨, Onomatsu, Osaka, 13.06.1998, 2014.03, , 178 cm 122 kg, J14', kimarite: 'oshidashi'}
] AS row

MERGE (basho:Basho {bashoId: row.bashoId})
  ON CREATE SET basho.name = row.bashoName
  ON MATCH SET basho.name = coalesce(basho.name, row.bashoName)

MERGE (day:Day {dayId: row.dayId})
  ON CREATE SET
    day.day = row.day,
    day.bashoId = row.bashoId,
    day.label = row.dateLabel
  ON MATCH SET
    day.day = coalesce(day.day, row.day),
    day.bashoId = coalesce(day.bashoId, row.bashoId),
    day.label = coalesce(day.label, row.dateLabel)

MERGE (basho)-[:HAS_DAY]->(day)

MERGE (bout:Bout {boutId: row.boutId})
  ON CREATE SET
    bout.matchupId = row.matchupId,
    bout.bashoId = row.bashoId,
    bout.day = row.day,
    bout.dateLabel = row.dateLabel,
    bout.eastId = row.eastId,
    bout.westId = row.westId,
    bout.winnerId = row.winnerId,
    bout.loserId = row.loserId,
    bout.kimarite = row.kimarite
  ON MATCH SET
    bout.matchupId = coalesce(bout.matchupId, row.matchupId),
    bout.bashoId = coalesce(bout.bashoId, row.bashoId),
    bout.day = coalesce(bout.day, row.day),
    bout.dateLabel = coalesce(bout.dateLabel, row.dateLabel),
    bout.eastId = coalesce(bout.eastId, row.eastId),
    bout.westId = coalesce(bout.westId, row.westId),
    bout.winnerId = coalesce(bout.winnerId, row.winnerId),
    bout.loserId = coalesce(bout.loserId, row.loserId),
    bout.kimarite = coalesce(bout.kimarite, row.kimarite)

MERGE (day)-[:HAS_BOUT]->(bout)

MERGE (east:Rikishi {rikishiId: row.eastId})
  ON CREATE SET
    east.name = row.eastName,
    east.fullRank = row.eastRank,
    east.title = row.eastTitle
  ON MATCH SET
    east.name = coalesce(east.name, row.eastName),
    east.fullRank = coalesce(east.fullRank, row.eastRank),
    east.title = CASE
      WHEN east.title IS NULL OR east.title = '' THEN row.eastTitle
      ELSE east.title
    END

MERGE (west:Rikishi {rikishiId: row.westId})
  ON CREATE SET
    west.name = row.westName,
    west.fullRank = row.westRank,
    west.title = row.westTitle
  ON MATCH SET
    west.name = coalesce(west.name, row.westName),
    west.fullRank = coalesce(west.fullRank, row.westRank),
    west.title = CASE
      WHEN west.title IS NULL OR west.title = '' THEN row.westTitle
      ELSE west.title
    END

MERGE (east)-[eastFight:FOUGHT_IN]->(bout)
  ON CREATE SET
    eastFight.side = 'east',
    eastFight.rank = row.eastRank
  ON MATCH SET
    eastFight.side = coalesce(eastFight.side, 'east'),
    eastFight.rank = coalesce(eastFight.rank, row.eastRank)
SET eastFight.result = CASE WHEN row.winnerId = row.eastId THEN 'win' ELSE 'loss' END

MERGE (west)-[westFight:FOUGHT_IN]->(bout)
  ON CREATE SET
    westFight.side = 'west',
    westFight.rank = row.westRank
  ON MATCH SET
    westFight.side = coalesce(westFight.side, 'west'),
    westFight.rank = coalesce(westFight.rank, row.westRank)
SET westFight.result = CASE WHEN row.winnerId = row.westId THEN 'win' ELSE 'loss' END

FOREACH (_ IN CASE WHEN row.kimarite IS NULL THEN [] ELSE [1] END |
  MERGE (k:Kimarite {name: row.kimarite})
  MERGE (bout)-[:USED_KIMARITE]->(k)
)

WITH row
MATCH (winner:Rikishi {rikishiId: row.winnerId})
MATCH (loser:Rikishi {rikishiId: row.loserId})
MERGE (winner)-[d:DEFEATED {boutId: row.boutId}]->(loser)
ON CREATE SET
  d.matchupId = row.matchupId,
  d.bashoId = row.bashoId,
  d.day = row.day,
  d.dateLabel = row.dateLabel,
  d.kimarite = row.kimarite
ON MATCH SET
  d.matchupId = coalesce(d.matchupId, row.matchupId),
  d.bashoId = coalesce(d.bashoId, row.bashoId),
  d.day = coalesce(d.day, row.day),
  d.dateLabel = coalesce(d.dateLabel, row.dateLabel),
  d.kimarite = coalesce(d.kimarite, row.kimarite);
